# ─── Bedrock Chat Audit Credentials ───────────────────────────────────────────
# Copy this to .env.audit and fill in values. NEVER commit .env.audit.
#
# Create a dedicated test account at bedrockchat.com — do NOT use a real user
# account. The test account will be authenticated and navigated through every
# route during the audit.

# Base URL (default: https://bedrockchat.com)
# Use http://localhost:3000 for local dev audits
AUDIT_BASE_URL=https://bedrockchat.com

# Standard test account (username OR email, must be waitlist-approved)
AUDIT_EMAIL=test-audit@bedrockchat.com
AUDIT_PASSWORD=<strong-random-password>

# Optional: parent account for family/parent-dashboard routes
# If not set, family routes will be skipped automatically
# AUDIT_PARENT_EMAIL=test-parent@bedrockchat.com
# AUDIT_PARENT_PASSWORD=<strong-random-password>

# Chrome DevTools Protocol port for Lighthouse (default: 9222)
# Change if 9222 is in use on your machine
# AUDIT_CDP_PORT=9222
