{
  "name": "bedrock-chat-audit",
  "private": true,
  "type": "module",
  "scripts": {
    "audit": "tsx run-audit.ts",
    "audit:mobile": "tsx run-audit.ts --strategy=mobile",
    "audit:desktop": "tsx run-audit.ts --strategy=desktop",
    "audit:route": "tsx run-audit.ts --route=/friends",
    "audit:compare": "tsx run-audit.ts --compare",
    "setup": "npx playwright install chromium"
  },
  "dependencies": {
    "@playwright/test": "^1.50.0",
    "chalk": "^5.4.1",
    "chrome-launcher": "^1.1.2",
    "lighthouse": "^12.4.0",
    "ora": "^8.2.0",
    "tsx": "^4.19.3"
  }
}
