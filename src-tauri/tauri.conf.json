{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bedrock Chat",
  "version": "../package.json",
  "identifier": "com.bedrocksystems.chat",
  "mainBinaryName": "bedrock-chat",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bedrock Chat",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "visible": false,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "Bedrock Chat"
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.livekit.cloud wss://*.livekit.cloud https://bedrockchat.com; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; media-src blob:; worker-src blob:",
      "freezePrototype": false,
      "dangerousDisableAssetCspModification": false
    }
  },
  "build": {
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out",
    "beforeDevCommand": {
      "script": "pnpm dev",
      "wait": false
    },
    "beforeBuildCommand": "TAURI_BUILD=true pnpm next build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": []
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://releases.bedrockchat.com/update/{{target}}/{{current_version}}"
      ],
      "pubkey": ""
    }
  }
}
